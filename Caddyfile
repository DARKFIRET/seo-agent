# Фикс 405 ошибки для oo7.fun
localhost, oo7.fun, www.oo7.fun {
    # Чтобы браузер не ругался на локальный oo7.fun (если вы его прописали в hosts)
    # tls internal

    # Ставим глобальный корень для статики
    root * dist/spa

    # ПРИОРИТЕТ 1: API запросы всегда на Node.js
    # Используем handle /api/* для абсолютной изоляции
    handle /api/* {
        reverse_proxy localhost:3000
    }

    # ПРИОРИТЕТ 1.5: Загруженные файлы (картинки кейсов и т.д.) на Node.js
    handle /uploads/* {
        reverse_proxy localhost:3000
    }

    # ПРИОРИТЕТ 2: Если запросили статику или SPA-маршрут (всё кроме /api/*)
    handle {
        # Сначала ищем реальный файл (картинка, css),
        # если нет — кидаем в index.html (для React роутинга)
        try_files {path} /index.html
        file_server
    }
}
