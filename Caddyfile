# Конфигурация для локального хостинга и oo7.fun
localhost, oo7.fun, www.oo7.fun {
    # Раскомментируйте, если сертификаты Let's Encrypt не выдаются (лимиты или порты закрыты)
    # tls internal

    root * dist/spa

    # 1. Запросы к API проксируем на Node.js (порт 3000)
    handle /api/* {
        reverse_proxy localhost:3000
    }

    # 2. Рендеринг фронтенда и статических файлов
    handle {
        # Сначала пробуем найти реальный файл в dist/spa, 
        # если его нет — отдаем index.html (для React Router)
        try_files {path} /index.html
        file_server
    }
}

# (Пример для продакшена на реальном сервере с авто-SSL)
