# PostgreSQL (Docker)
POSTGRES_DB=lumina
POSTGRES_USER=lumina
POSTGRES_PASSWORD=lumina_secret

# Drizzle / server connection string
DATABASE_URL=postgresql://lumina:lumina_secret@localhost:5432/lumina

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Optional — email notifications when a lead is submitted
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=465
# SMTP_USER=hello@luminaagency.ru
# SMTP_PASS=
# NOTIFY_EMAIL=hello@luminaagency.ru
